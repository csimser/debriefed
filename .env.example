# =============================================================================
# Debriefed — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
#
#   cp .env.example .env.local
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-only.
# =============================================================================


# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-here
# Service role key — bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# Postgres connection string — used by scripts/seed-database.mjs and pg_dump.
# Use the SHARED POOLER (Session mode, port 5432), NOT the direct connection.
# The direct host is IPv6-only on the free tier and fails on IPv4-only networks (e.g. WSL2).
# Dashboard: Settings → Database → Connection string → URI → toggle "Shared Pooler" → Session.
# Format: postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-east-1.pooler.supabase.com:5432/postgres


# ─── Anthropic Claude API (REQUIRED for AI features) ────────────────────────
# Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here


# ─── Stripe (REQUIRED for payments — optional if PAYMENTS_ENABLED=false) ────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_your_key

# Webhook signing secret from: Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_your_signing_secret

# Price IDs from: Dashboard → Products → your price → "API ID"
STRIPE_CORE_PRICE_ID=price_your_core_tier
STRIPE_FULL_PRICE_ID=price_your_full_tier
STRIPE_EVAL_PACK_PRICE_ID=price_your_eval_pack


# ─── Resend (REQUIRED for transactional email) ──────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# From-address for outgoing email. Must be on a domain you have verified in Resend.
MAIL_FROM=noreply@yourdomain.com
# Optional friendly-named version (e.g., "Your App <noreply@yourdomain.com>")
MAIL_FROM_NAMED=Your App <noreply@yourdomain.com>
# Where waitlist signup notifications are sent (defaults to MAIL_FROM if unset)
WAITLIST_NOTIFY_TO=team@yourdomain.com


# ─── O*NET API (REQUIRED for MOS crosswalk lookups) ─────────────────────────
# Register: https://services.onetcenter.org/developer/signup
ONET_API_KEY=your-onet-key


# ─── Unsubscribe Token Signing (REQUIRED) ───────────────────────────────────
# Used for HMAC-signing one-click email unsubscribe links.
# Generate with: openssl rand -hex 32
UNSUBSCRIBE_SECRET=generate_a_64_char_random_hex_string


# ─── App Configuration (REQUIRED) ───────────────────────────────────────────
# Public base URL of your deployment (no trailing slash).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public support email shown on /privacy, /terms, /help, /pricing.
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com


# ─── Admin Access (OPTIONAL) ────────────────────────────────────────────────
# Comma-separated list of emails that bypass all usage limits.
# Example: ADMIN_BYPASS_EMAILS="admin@example.com,owner@example.com"
ADMIN_BYPASS_EMAILS=

# UUID of a single super-admin user. Grants admin UI access.
# Look up in Supabase: Authentication → Users → click user → User UID
SUPER_ADMIN_USER_ID=


# ─── Cron Jobs (REQUIRED if you deploy /api/cron/* endpoints) ───────────────
# Used to authenticate Vercel Cron requests via `Authorization: Bearer <secret>`.
# Generate with: openssl rand -hex 32
CRON_SECRET=generate_a_random_string


# ─── Sentry (OPTIONAL — error monitoring) ───────────────────────────────────
# Dashboard: https://sentry.io → Settings → Projects → your project → Client Keys
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Required only for source map uploads during build
SENTRY_AUTH_TOKEN=


# ─── Google Search Console (OPTIONAL) ───────────────────────────────────────
# Get from: https://search.google.com/search-console → Settings → Ownership verification
NEXT_PUBLIC_GSC_VERIFICATION=


# ─── Feature Flags (OPTIONAL) ───────────────────────────────────────────────
# Set to "false" to disable Stripe checkout and grant tiers directly via admin.
NEXT_PUBLIC_PAYMENTS_ENABLED=true

# Set to "true" to show a launch coupon banner on /pricing.
NEXT_PUBLIC_SHOW_LAUNCH_COUPON=false

# Set to "true" to enable the redesigned 4-step onboarding flow.
NEXT_PUBLIC_NEW_ONBOARDING=true


# ─── Scripts-Only (OPTIONAL) ────────────────────────────────────────────────
# Override email used by scripts/test-unsubscribe.mjs
TEST_EMAIL=test@example.com
